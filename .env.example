# Copy to .env for local overrides. docker-compose already sets DATABASE_URL
# for the api service; these defaults match the compose network.

DATABASE_URL=postgresql+psycopg2://griddock:griddock@db:5432/griddock
DATA_DIR=/app/data

# Source data paths (inside the container; ./data is mounted read-only).
SESSIONS_MD_PATH=/app/data/source/nml_ev_sessions.md
SESSIONS_CSV_PATH=/app/data/NML_ev_sessions.csv
GOLDEN_INTEGRATED_PATH=/app/data/_golden_integrated_pool_smard_15min.csv
GOLDEN_AGGREGATE_PATH=/app/data/_golden_aggregate_pool_15min.csv
